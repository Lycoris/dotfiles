{
  "Footnote": {
    "prefix": "fnt",
    "body": [
      "[^${1:Footnote}]$0",
      "",
      "[^$1]: ${2:Text}"
    ],
    "description": "脚注の参照と定義を挿入"
  },
  "Section": {
    "prefix": "sec",
    "body": [
      "# ${1:Section Name}",
      "$0"
    ],
    "description": "見出し (h1)"
  },
  "Sub Section": {
    "prefix": "ssec",
    "body": [
      "## ${1:Section Name}",
      "$0"
    ],
    "description": "見出し (h2)"
  },
  "SubSub Section": {
    "prefix": "sssec",
    "body": [
      "### ${1:Section Name}",
      "$0"
    ],
    "description": "見出し (h3)"
  },
  "Paragraph": {
    "prefix": "par",
    "body": [
      "#### ${1:Paragraph Name}",
      "$0"
    ],
    "description": "見出し (h4)"
  },
  "Sub Paragraph": {
    "prefix": "spar",
    "body": [
      "##### ${1:Paragraph Name}",
      "$0"
    ],
    "description": "見出し (h5)"
  },
  "Link": {
    "prefix": "link",
    "body": [
      "[${1:Text}](${2:https://www.url.com})$0"
    ],
    "description": "リンク"
  },
  "Image": {
    "prefix": "img",
    "body": [
      "![${1:alt}](${2:path} \"${3:title}\")$0"
    ],
    "description": "画像"
  },
  "Inline Code": {
    "prefix": "ilc",
    "body": [
      "`${1}`$0"
    ],
    "description": "インラインコード"
  },
  "Codeblock": {
    "prefix": "cbl",
    "body": [
      "```${1:language}",
      "$2",
      "```",
      "$0"
    ],
    "description": "コードブロック"
  },
  "Reference Link": {
    "prefix": "refl",
    "body": [
      "[${1:Text}][${2:id}]$0",
      "",
      "[$2]: ${3:https://www.url.com} \"${4:title}\""
    ],
    "description": "参照リンク"
  },
  "Comment": {
    "prefix": "/*",
    "body": [
      "<!-- ${1} -->$0"
    ],
    "description": "HTMLコメント"
  }
}
