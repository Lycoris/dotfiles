[
    // Tab / Shift+Tab でタブ切り替え (nmap <Tab> gt / nmap <S-Tab> gT)
    // Claude Code のパネル/サイドバーにフォーカスがあるときは除外
    {
        "key": "tab",
        "command": "workbench.action.nextEditor",
        "when": "!editorTextFocus && !terminalFocus && !inQuickOpen && activeWebviewPanelId != 'claudeVSCodePanel' && !claude-vscode.sideBarActive"
    },
    {
        "key": "shift+tab",
        "command": "workbench.action.previousEditor",
        "when": "!editorTextFocus && !terminalFocus && !inQuickOpen && activeWebviewPanelId != 'claudeVSCodePanel' && !claude-vscode.sideBarActive"
    },
    // Vim ノーマルモードでも Tab / Shift+Tab でタブ切り替え
    {
        "key": "tab",
        "command": "workbench.action.nextEditor",
        "when": "editorTextFocus && vim.mode == 'Normal' && !inQuickOpen"
    },
    {
        "key": "shift+tab",
        "command": "workbench.action.previousEditor",
        "when": "editorTextFocus && vim.mode == 'Normal' && !inQuickOpen"
    }
]
