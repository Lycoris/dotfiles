cask "calibre"
cask "google-chrome"
cask "google-japanese-ime"
cask "iterm2"
cask "maccy"
cask "mactex"
cask "macvim-app"
cask "obs"
cask "skim"
cask "spotify"
cask "todoist-app"
cask "toggl-track"
