# set arguments for all 'brew install --cask' commands
cask_args appdir: "/Applications"

# =====================
# CLI tools (brew install)
# =====================
brew "autoconf"
brew "autossh"
brew "cmake"
brew "curl"
brew "deno"
brew "fontforge"
brew "fzf"
brew "ghostscript"
brew "git"
brew "git-ftp"
brew "gnupg"
brew "hugo"
brew "imagemagick"
brew "lua"
brew "mas"
brew "mise"
brew "openssl@3"
brew "pandoc"
brew "python"
brew "sheldon"
brew "terminal-notifier"
brew "texlab"
brew "tig"
brew "tmux"
brew "wget"
brew "xpdf"
brew "zsh"

